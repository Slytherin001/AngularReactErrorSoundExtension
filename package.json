{
  "name": "angular-react-error-sound",
  "displayName": "Error Sound Support For All Coding Languages (REACT, ANGULAR, JAVASCRIPT, TYPESCRIPT, PYTHON and More)",
  "description": "Play a sound on saving files if errors exist. Supports JavaScript, TypeScript, Angular, React, Python, and more.",
  "publisher": "MdKaifAli",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Slytherin001/AngularReactErrorSoundExtension.git"
  },
  "categories": [
    "Other"
  ],
  "icon": "angular-error.png",
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Error Sound Settings",
      "properties": {
        "errorSound.selectedSound": {
          "type": "string",
          "default": "meow-ghoop-ghopp.wav",
          "enum": [
            "meow-ghoop-ghopp.wav",
            "faaah.wav",
            "anime-ahh.wav",
            "kya-cheda-bhosdi.wav",
            "aayein-meme.wav",
            "le-beta.wav",
            "shocked-sound-effect.wav",
            "khatam-rahul-gandhi.wav",
            "meri-jung-emotional.wav",
            "dry-fart.wav",
            "eww-brother-eww"
          ],
          "description": "Select error sound from media folder"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
